  "title": "proposal_withdrawals",
  "description": "proposal_withdrawals schema from Blockfrost API",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "stake_address": {
        "type": "string",
        "example": "stake1ux3g2c9dx2nhhehyrezyxpkstartcqmu9hk63qgfkccw5rqttygt7",
